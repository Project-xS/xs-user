{
  auto_https off
}

:3000 {
  handle_path /app* {
    reverse_proxy 127.0.0.1:7357
  }

  @installRoutes path / /index.html /manifest.webmanifest /manifest.json
  handle @installRoutes {
    root * /srv/install

    @installManifest path /manifest.webmanifest /manifest.json
    header @installManifest Content-Type "application/manifest+json; charset=utf-8"
    rewrite /manifest.json /manifest.webmanifest

    try_files {path} /index.html
    file_server
  }

  handle {
    reverse_proxy 127.0.0.1:7357
  }
}
